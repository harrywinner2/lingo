# Copy to .env and fill in.

# Dev: SQLite. Prod: a Postgres URL, e.g. from Supabase/Neon
#   postgresql://USER:PASS@HOST:5432/DB?sslmode=require
# (also switch datasource provider in prisma/schema.prisma to "postgresql")
DATABASE_URL="file:./dev.db"

# Required. Generate with: npx auth secret
AUTH_SECRET=""

# Set "true" for one-click dev sign-in without configuring OAuth. Disable in prod.
AUTH_DEV_LOGIN="true"

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {APP_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Storage driver: local | r2  (r2 requires the R2_* vars below)
STORAGE_DRIVER="local"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""
