# Copy to .env and fill in.

# Dev: SQLite. Prod: a Postgres URL, e.g. from Supabase/Neon
#   postgresql://USER:PASS@HOST:5432/DB?sslmode=require
# (also switch datasource provider in prisma/schema.prisma to "postgresql")
DATABASE_URL="file:./dev.db"

# Required. Generate with: npx auth secret
AUTH_SECRET=""

# Set "true" for one-click dev sign-in without configuring OAuth. Disable in prod.
AUTH_DEV_LOGIN="true"

# Google OAuth — create a "Web application" client at
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be EXACTLY: {APP_URL}/api/auth/callback/google
#   dev:  http://localhost:3000/api/auth/callback/google
# Then set NEXT_PUBLIC_GOOGLE_ENABLED=true to show the button.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
NEXT_PUBLIC_GOOGLE_ENABLED="false"

# Legacy t2t translator: the Redis the Python worker (infer.py) listens on.
# Powers the /translate page. Leave blank to disable that page's backend.
REDIS_URL=""

# Storage driver: local | r2  (r2 requires the R2_* vars below)
STORAGE_DRIVER="local"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# Audio preprocessing pipeline. When "true", uploads are queued for the Python
# worker (worker/) and marked ready once normalized. Off => ready immediately.
PREPROCESS_ENABLED="false"
# Shared secret for the worker's callback to /api/internal/* (must match worker).
INTERNAL_API_SECRET=""

# Public base URL, used to build magic links sent over email/SMS.
# e.g. https://lingo.cm  (falls back to the request host if unset)
APP_URL=""

# Magic-link delivery. Leave blank to fall back to copy/share links.
# Email via Resend (https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="Lingo <noreply@lingo.cm>"
# SMS via Twilio (https://twilio.com)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
