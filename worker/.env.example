# Preprocessing worker config. Copy to worker/.env and fill in.
# This worker runs in the cloud (NOT the home desktop, which only serves t2t).

REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# Cloudflare R2 (S3-compatible) — the primary audio store
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="lingo-audio"

# The Lingo app's internal callback API + shared secret (must match the app's
# INTERNAL_API_SECRET). Use the app's public URL, e.g. https://lingo.cm
INTERNAL_API_URL="https://lingo.cm"
INTERNAL_API_SECRET=""
