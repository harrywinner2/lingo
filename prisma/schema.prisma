// Lingo / NativeAI v2 schema.
// Dev: SQLite (zero-config). Prod: switch provider to "postgresql" + DATABASE_URL.
// Enums are modeled as String (with documented values) to stay SQLite-portable.

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters", "queryCompiler"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A language a researcher can target. Built-ins are seeded; researchers can
// also create their own (just a name + the countries where it's spoken).
model Language {
  id          String   @id @default(cuid())
  code        String   @unique // slug, e.g. "bafia"
  name        String
  countries   String   @default("") // comma-separated country names
  custom      Boolean  @default(false)
  createdById String?
  createdAt   DateTime @default(now())
}

// ---------- Auth.js (NextAuth) ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  locale        String    @default("en")
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]

  ownedCampaigns Campaign[]    @relation("CampaignOwner")
  memberships    Membership[]
  prompts        Prompt[]      @relation("PromptCreator")
  recordings     Recording[]
  verifications  Verification[]
  ledger         PointLedger[]
  redemptions    Redemption[]
  invitesCreated Invite[]      @relation("InviteCreator")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Domain ----------

model Campaign {
  id          String   @id @default(cuid())
  ownerId     String
  title       String
  description String?
  targetLang     String // language code, e.g. "bafia"
  targetLangName String? // denormalized display name (supports custom languages)
  pivotLang   String   @default("en") // language prompts are presented in
  status      String   @default("active") // draft | active | paused | closed
  visibility  String   @default("private") // private | open (listed in Discover)
  autoQualify Boolean  @default(false) // auto-promote probation members by scores
  budgetPoints  Int    @default(0)
  spentPoints   Int    @default(0)
  rewardRecord  Int    @default(15) // points per accepted recording
  rewardVerify  Int    @default(5)  // points per verification
  minVerifications Int @default(3)  // verdicts needed before a recording is decided
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User         @relation("CampaignOwner", fields: [ownerId], references: [id])
  memberships Membership[]
  prompts     Prompt[]
  recordings  Recording[]
  invites     Invite[]
  rewards     Reward[]
  redemptions Redemption[]
  magicLinks  MagicLink[]

  @@index([ownerId])
}

model Membership {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  role       String // owner | manager | speaker | verifier | reviewer
  status     String   @default("active") // active | suspended
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId, role])
  @@index([userId])
}

model Invite {
  id          String   @id @default(cuid())
  campaignId  String
  role        String // speaker | verifier | reviewer | manager
  code        String   @unique
  email       String?
  createdById String
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User     @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([campaignId])
}

// A reusable, campaign-scoped sign-in link for an imported participant (who may
// have no email/OAuth). Visiting it signs them straight into an account joined
// to that campaign.
model MagicLink {
  id          String    @id @default(cuid())
  token       String    @unique
  campaignId  String
  role        String // speaker | verifier | reviewer
  name        String?
  email       String?
  phone       String?
  userId      String? // set on first use
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model Prompt {
  id               String   @id @default(cuid())
  campaignId       String
  pivotText        String
  pivotLang        String   @default("en")
  targetLang       String
  domain           String?
  sceneDescription String?
  imageUrl         String?
  ttsUrl           String?
  difficulty       String?  // easy | medium | hard
  targetN          Int      @default(3) // desired number of recordings
  status           String   @default("live") // draft | live | retired
  source           String   @default("manual") // manual | csv | ai
  createdById      String?
  createdAt        DateTime @default(now())

  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy  User?       @relation("PromptCreator", fields: [createdById], references: [id])
  recordings Recording[]

  @@index([campaignId, status])
}

model Recording {
  id         String   @id @default(cuid())
  promptId   String
  campaignId String
  speakerId  String
  audioUrl   String // currently-servable URL (raw while pending, clean once processed)
  rawKey     String? // R2 key of the raw upload (purged after preprocessing)
  cleanKey   String? // R2 key of the normalized clip kept for grading/training
  qualityMetrics String? // JSON: duration, sampleRate, loudness, clipping, etc.
  rawDeleted     Boolean @default(false)
  deliveredToDrive Boolean @default(false)
  mimeType   String   @default("audio/webm")
  durationMs Int      @default(0)
  status     String   @default("ready") // uploaded | processing | ready | accepted | rejected
  score      Float? // consensus score once decided
  createdAt  DateTime @default(now())

  prompt        Prompt         @relation(fields: [promptId], references: [id], onDelete: Cascade)
  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  speaker       User           @relation(fields: [speakerId], references: [id])
  verifications Verification[]

  @@index([campaignId, status])
  @@index([promptId])
}

model Verification {
  id          String   @id @default(cuid())
  recordingId String
  verifierId  String
  verdict     String // correct | average | incorrect
  comment     String?
  createdAt   DateTime @default(now())

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  verifier  User      @relation(fields: [verifierId], references: [id])

  @@unique([recordingId, verifierId])
  @@index([verifierId])
}

model PointLedger {
  id           String   @id @default(cuid())
  userId       String
  campaignId   String?
  amount       Int
  reason       String // contribution | verification | quality_bonus | redemption | adjustment
  refId        String?
  balanceAfter Int
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// A researcher-defined reward: a prize that costs a number of points.
model Reward {
  id          String   @id @default(cuid())
  campaignId  String
  title       String // "5,000 XAF mobile money", "Bag of rice"
  description String?
  costPoints  Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  redemptions Redemption[]

  @@index([campaignId])
}

model Redemption {
  id          String    @id @default(cuid())
  userId      String
  campaignId  String
  rewardId    String?
  rewardTitle String? // snapshot of the reward title at redemption time
  points      Int
  status      String    @default("open") // open | redeemed | rejected
  note        String?
  handledById String?
  handledAt   DateTime?
  createdAt   DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reward   Reward?   @relation(fields: [rewardId], references: [id])

  @@index([campaignId, status])
  @@index([userId])
}
